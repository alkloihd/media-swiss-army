# Dependencies
node_modules/
node_modules
node_modules.nosync/

# System / logs
.DS_Store
*.log

# Environment / secrets
.env
.env.*
.env.nosync

# Local dev artifacts (MCP, test tooling, screenshots)
.playwright-mcp/
.superpowers/
screenshots/

# Claude Code config
# .claude/settings.json IS tracked on main — team-shared permissions, MCP
# enables, env flags. Every feature branch off main inherits the same agent
# capabilities (incl. xcodebuildmcp, context7, and TestFlight deploy access).
# .claude/settings.local.json is the per-user override (personal MCP, machine
# keys) — gitignored, never committed.
.claude/settings.local.json
.claude/plans/
.claude/worktrees/

# Agent session activity logs (raw shell-history per session) only.
# All planning docs, AI-CHAT-LOG.md, HANDOFF.md, PLAN-*, AUDIT-*, BACKLOG-*
# under .agents/work-sessions/ ARE tracked — they're the project's
# decision history and need to be reachable from phone via github.com.
.agents/work-sessions/**/session-activity.log

# `Docs/` (capital-D) was an ad-hoc chat-export dump and is gitignored.
# `docs/` (lowercase) is the structured project documentation folder
# (superpowers plans, design notes) and IS tracked. macOS's
# case-insensitive filesystem means a bare `Docs/` rule blocks both, so
# we negate `docs/` explicitly. Order matters: ignore Docs/ first, then
# unignore docs/.
Docs/
!docs/
!docs/**
